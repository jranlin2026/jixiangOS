NODE_ENV=production

# MySQL. Use a strong password in production or replace this with an Alibaba Cloud RDS URL.
DATABASE_URL="mysql://jixiang_os:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:3306/jixiang_os"

# Express API listens on localhost. Nginx proxies /api to this port.
AI_PROXY_HOST=127.0.0.1
AI_PROXY_PORT=3001
CORS_ORIGINS="https://crm.example.com"

# Frontend build settings.
VITE_USE_BACKEND_API=true
VITE_AI_API_BASE="/api"

# Private, server-only location for original enablement Markdown files.
# ENABLEMENT_PRIVATE_STORAGE_DIR=private_uploads/enablement

# AI provider.
DEEPSEEK_API_KEY=""

# Required in production. Do not use the local development defaults on a cloud server.
# Use at least 12 characters with mixed upper/lowercase letters, digits, and symbols.
JIXIANG_DEFAULT_ADMIN_PASSWORD=""
JIXIANG_DEFAULT_USER_PASSWORD=""

# Server-only HMAC key for the one-time customer permission migration manifest.
# Generate at least 32 random bytes; use the same secret for capture, apply, and release startup.
CUSTOMER_PERMISSION_MIGRATION_SIGNING_KEY=""

# Server-only HMAC key for 15-minute customer import precheck confirmations.
# Generate an independent key with at least 32 random characters.
CUSTOMER_DATA_EXCHANGE_SIGNING_KEY=""

# Dedicated server-only contact identity keys. These are not interchangeable
# with the permission-migration signing key. Generate independent 32-byte
# base64 values (for example: openssl rand -base64 32). Versions stay pinned to
# 1 until an explicit rotation and rehash migration is available.
CONTACT_IDENTITY_HMAC_KEY=""
CONTACT_IDENTITY_HMAC_KEY_VERSION=1
CONTACT_IDENTITY_ENCRYPTION_KEY=""
CONTACT_IDENTITY_ENCRYPTION_KEY_VERSION=1

# Versioned AES-256-GCM keys for reversible customer merges. The JSON object
# maps positive integer versions to independent 32-byte base64 keys. Keep every
# version referenced by a merge whose 72-hour undo window is still open.
CUSTOMER_MERGE_SNAPSHOT_ACTIVE_KEY_VERSION=1
CUSTOMER_MERGE_SNAPSHOT_KEYS_JSON='{"1":""}'

# Database backup scripts.
JIXIANG_MYSQL_HOST=127.0.0.1
JIXIANG_MYSQL_PORT=3306
JIXIANG_MYSQL_DATABASE=jixiang_os
JIXIANG_MYSQL_USER=jixiang_os
JIXIANG_MYSQL_PASSWORD=""
JIXIANG_BACKUP_DIR=/var/backups/jixiang-os
JIXIANG_BACKUP_KEEP_DAYS=14

# Deployment helper scripts.
JIXIANG_APP_DIR=/var/www/jixiang-os/current
JIXIANG_DEPLOY_BRANCH=main
JIXIANG_DEPLOY_BACKUP=true
JIXIANG_HEALTH_URL=http://127.0.0.1:3001/api/ready
JIXIANG_SMOKE_BASE_URL=""
# Keep empty until the production Prisma migration baseline has been verified.
JIXIANG_PRISMA_BASELINE_CONFIRMED=""
JIXIANG_SMOKE_PASSWORD=""

# Local-only customer-tag QA. Both API and MySQL must use loopback hosts.
# The database name must contain _qa or _test and exactly match QA_DATABASE_NAME.
QA_API_BASE=http://127.0.0.1:3001/api
QA_DATABASE_NAME=jixiang_os_qa
QA_ALLOW_DESTRUCTIVE_DB=false
QA_ADMIN_ACCOUNT=""
QA_ADMIN_PASSWORD=""
QA_SALES_ACCOUNT=""
QA_SALES_PASSWORD=""

# Public login protection.
JIXIANG_SESSION_TTL_HOURS=12
JIXIANG_REMEMBER_SESSION_DAYS=30
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_BLOCK_MS=900000
