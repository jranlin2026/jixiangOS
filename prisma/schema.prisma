generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Department {
  id          String   @id @db.VarChar(64)
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(64)
  description String?  @db.VarChar(500)
  parentId    String?  @db.VarChar(64)
  managerId   String?  @db.VarChar(64)
  memberCount Int      @default(0)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@map("departments")
}

model Position {
  id           String   @id @db.VarChar(64)
  name         String   @db.VarChar(100)
  code         String   @unique @db.VarChar(64)
  departmentId String?  @db.VarChar(64)
  description  String?  @db.VarChar(500)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([departmentId])
  @@map("positions")
}

model Role {
  id           String   @id @db.VarChar(64)
  name         String   @db.VarChar(100)
  code         String   @unique @db.VarChar(64)
  description  String?  @db.VarChar(500)
  departmentId String?  @db.VarChar(64)
  permissions  Json
  dataScopes   Json?
  memberCount  Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([departmentId])
  @@map("roles")
}

model User {
  id                String    @id @db.VarChar(64)
  name              String    @db.VarChar(100)
  account           String?   @unique @db.VarChar(100)
  email             String    @unique @db.VarChar(200)
  phone             String    @db.VarChar(50)
  role              String    @db.VarChar(100)
  avatar            String?   @db.VarChar(500)
  departmentId      String?   @db.VarChar(64)
  positionId        String?   @db.VarChar(64)
  positionName      String?   @db.VarChar(100)
  roleId            String?   @db.VarChar(64)
  passwordHash      String?   @db.VarChar(100)
  passwordSalt      String?   @db.VarChar(100)
  passwordUpdatedAt DateTime?
  mustChangePassword Boolean   @default(false)
  lastLoginAt       DateTime?
  isActive          Boolean   @default(true)
  employmentStatus  String    @default("active") @db.VarChar(20)
  leftAt            DateTime?
  leftBy            String?   @db.VarChar(100)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions AuthSession[]

  @@index([departmentId])
  @@index([roleId])
  @@map("users")
}

model AuthSession {
  id        String    @id @db.VarChar(64)
  token     String    @unique @db.VarChar(120)
  userId    String    @db.VarChar(64)
  remember  Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model AppStorage {
  key       String   @id @db.VarChar(120)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_storage")
}

model AiProviderConfig {
  id        String   @id @default("default") @db.VarChar(32)
  provider  String   @default("deepseek") @db.VarChar(40)
  apiKey    String   @db.Text
  baseUrl   String   @default("https://api.deepseek.com") @db.VarChar(255)
  model     String   @default("deepseek-chat") @db.VarChar(100)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_provider_configs")
}

enum CoCreationStatus {
  DRAFT
  INTERVIEWING
  EMPLOYEE_CONFIRMATION
  FACT_CONFIRMATION
  MANAGEMENT_REVIEW
  VALIDATION_APPROVED
  VALIDATING
  PROJECT_DECISION
  APPROVED
  DEFERRED
  MERGED
  REJECTED
}

enum CoCreationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model CoCreationRequest {
  id              String           @id @db.VarChar(64)
  title           String           @db.VarChar(200)
  status          CoCreationStatus @default(DRAFT)
  requesterId     String           @db.VarChar(64)
  requesterName   String           @db.VarChar(100)
  departmentId    String?          @db.VarChar(64)
  supervisorId    String?          @db.VarChar(64)
  mergedIntoId    String?          @db.VarChar(64)
  decisionReason  String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  messages   CoCreationMessage[]
  brief      CoCreationBrief?
  validation CoCreationValidation?
  events     CoCreationEvent[]

  @@index([requesterId, createdAt])
  @@index([departmentId, status])
  @@index([supervisorId, status])
  @@index([status, updatedAt])
  @@map("co_creation_requests")
}

model CoCreationMessage {
  id        String                @id @db.VarChar(64)
  requestId String                @db.VarChar(64)
  role      CoCreationMessageRole
  content   String                @db.Text
  metadata  Json?
  createdAt DateTime              @default(now())

  request CoCreationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@map("co_creation_messages")
}

model CoCreationBrief {
  id                  String   @id @db.VarChar(64)
  requestId           String   @unique @db.VarChar(64)
  problemStatement    String   @db.Text
  currentWorkflow     String   @db.Text
  painPoints          Json
  affectedRoles       Json
  frequency           String?  @db.VarChar(100)
  impact              String?  @db.Text
  desiredOutcome      String   @db.Text
  acceptanceCriteria  Json
  evidence            Json
  employeeStatements  Json
  aiHypotheses        Json
  confirmedFacts      Json
  openQuestions       Json
  classification      String?  @db.VarChar(100)
  prioritySuggestion  String?  @db.VarChar(20)
  completeness        Int      @default(0)
  employeeConfirmedAt DateTime?
  factsConfirmedAt    DateTime?
  factsConfirmedBy    String?  @db.VarChar(64)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  request CoCreationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("co_creation_briefs")
}

model CoCreationValidation {
  id                  String   @id @db.VarChar(64)
  requestId           String   @unique @db.VarChar(64)
  ownerId              String?  @db.VarChar(64)
  plan                 Json
  evidence             Json
  confirmedFacts       Json
  metrics              Json
  unresolvedQuestions  Json
  recommendation       String?  @db.Text
  conclusion           String?  @db.Text
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  request CoCreationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("co_creation_validations")
}

model CoCreationEvent {
  id        String   @id @db.VarChar(64)
  requestId String   @db.VarChar(64)
  actorId   String   @db.VarChar(64)
  actorName String   @db.VarChar(100)
  action    String   @db.VarChar(100)
  fromState String?  @db.VarChar(50)
  toState   String?  @db.VarChar(50)
  detail    Json?
  createdAt DateTime @default(now())

  request CoCreationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
  @@index([actorId, createdAt])
  @@map("co_creation_events")
}

model LeadRecord {
  id                  String   @id @db.VarChar(64)
  name                String   @db.VarChar(120)
  company             String?  @db.VarChar(200)
  phone               String?  @db.VarChar(50)
  wechat              String?  @db.VarChar(100)
  source              String?  @db.VarChar(120)
  status              String?  @db.VarChar(50)
  lifecycleStatusCode String?  @db.VarChar(80)
  owner               String?  @db.VarChar(100)
  assignedTo          String?  @db.VarChar(100)
  inputBy             String?  @db.VarChar(100)
  leadContributorId   String?  @db.VarChar(64)
  data                Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([phone])
  @@index([owner])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
  @@map("lead_records")
}

model BusinessRecord {
  id         String   @id @db.VarChar(160)
  domain     String   @db.VarChar(80)
  recordId   String   @db.VarChar(80)
  title      String?  @db.VarChar(240)
  status     String?  @db.VarChar(80)
  owner      String?  @db.VarChar(120)
  customerId String?  @db.VarChar(80)
  orderId    String?  @db.VarChar(80)
  amount     Decimal? @db.Decimal(14, 2)
  eventAt    DateTime?
  mergedIntoId  String?   @db.VarChar(80)
  mergedAt      DateTime?
  mergedById    String?   @db.VarChar(64)
  mergedByName  String?   @db.VarChar(100)
  mergeLedgerId String?   @db.VarChar(64)
  recordRevision Int      @default(0)
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([domain, recordId])
  @@index([domain])
  @@index([domain, status])
  @@index([domain, eventAt, createdAt])
  @@index([status])
  @@index([owner])
  @@index([customerId])
  @@index([orderId])
  @@index([eventAt])
  @@index([domain, mergedIntoId])
  @@index([domain, mergeLedgerId])
  @@map("business_records")
}

enum CustomerTodoStatus {
  PENDING
  COMPLETED
  CANCELED
}

model CustomerTodo {
  id               String             @id @db.VarChar(64)
  customerId       String             @db.VarChar(80)
  customerName     String             @db.VarChar(200)
  title            String             @db.VarChar(120)
  content          String?            @db.Text
  status           CustomerTodoStatus @default(PENDING)
  dueAt            DateTime
  executionMethod  String             @default("none") @db.VarChar(20)
  assigneeId       String             @db.VarChar(64)
  assigneeName     String             @db.VarChar(100)
  createdById      String             @db.VarChar(64)
  createdByName    String             @db.VarChar(100)
  completedAt      DateTime?
  completedById    String?            @db.VarChar(64)
  completedByName  String?            @db.VarChar(100)
  canceledAt       DateTime?
  canceledById     String?            @db.VarChar(64)
  canceledByName   String?            @db.VarChar(100)
  cancelReason     String?            @db.VarChar(500)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([customerId, status, dueAt])
  @@index([assigneeId, status, dueAt])
  @@map("customer_todos")
}

model KnowledgeDocument {
  id                String   @id @db.VarChar(64)
  slug              String   @unique @db.VarChar(160)
  title             String   @db.VarChar(240)
  category          String   @db.VarChar(120)
  summary           String   @db.Text
  ownerDepartmentId String?  @db.VarChar(64)
  ownerUserId       String?  @db.VarChar(64)
  sensitivity       String   @default("INTERNAL") @db.VarChar(32)
  currentVersionId  String?  @db.VarChar(64)
  createdById       String   @db.VarChar(64)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  versions     KnowledgeVersion[]
  visibilities KnowledgeVisibility[]

  @@index([ownerDepartmentId])
  @@index([ownerUserId])
  @@index([currentVersionId])
  @@map("knowledge_documents")
}

model KnowledgeVersion {
  id             String    @id @db.VarChar(64)
  documentId     String    @db.VarChar(64)
  versionNumber  Int
  status         String    @default("DRAFT") @db.VarChar(32)
  sourceFileName String    @db.VarChar(255)
  sourcePath     String?   @db.VarChar(1000)
  checksum       String    @db.VarChar(64)
  contentText    String    @db.LongText
  effectiveAt    DateTime?
  expiresAt      DateTime?
  publishedAt    DateTime?
  publishedById  String?   @db.VarChar(64)
  createdById    String    @db.VarChar(64)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  document    KnowledgeDocument     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  attachments KnowledgeAttachment[]
  reviews     ContentReview[]
  chunks      KnowledgeChunk[]

  @@unique([documentId, versionNumber])
  @@index([status])
  @@index([effectiveAt, expiresAt])
  @@map("knowledge_versions")
}

model KnowledgeAttachment {
  id          String   @id @db.VarChar(64)
  versionId   String   @db.VarChar(64)
  fileName    String   @db.VarChar(255)
  mimeType    String   @db.VarChar(120)
  byteSize    Int
  storageKey  String   @unique @db.VarChar(500)
  checksum    String   @db.VarChar(64)
  createdById String   @db.VarChar(64)
  createdAt   DateTime @default(now())

  version KnowledgeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId])
  @@map("knowledge_attachments")
}

model KnowledgeVisibility {
  id          String   @id @db.VarChar(64)
  documentId  String   @db.VarChar(64)
  subjectType String   @db.VarChar(32)
  subjectId   String   @default("*") @db.VarChar(64)
  createdAt   DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, subjectType, subjectId])
  @@index([subjectType, subjectId])
  @@map("knowledge_visibilities")
}

model ContentReview {
  id             String   @id @db.VarChar(64)
  versionId      String   @db.VarChar(64)
  reviewerUserId String   @db.VarChar(64)
  decision       String   @db.VarChar(24)
  comment        String?  @db.Text
  reviewedAt     DateTime @default(now())

  version KnowledgeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, reviewedAt])
  @@map("content_reviews")
}

model KnowledgeChunk {
  id         String   @id @db.VarChar(64)
  versionId  String   @db.VarChar(64)
  ordinal    Int
  heading    String?  @db.VarChar(500)
  content    String   @db.LongText
  searchText String   @db.LongText
  createdAt  DateTime @default(now())

  version KnowledgeVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, ordinal])
  @@index([versionId])
  @@map("knowledge_chunks")
}

model CustomerBatchPrecheck {
  id                      String   @id @db.VarChar(64)
  actorId                 String   @db.VarChar(64)
  handlerKey              String   @db.VarChar(80)
  operation               String   @db.VarChar(80)
  status                  String   @db.VarChar(32)
  tokenHash               String   @unique @db.Char(64)
  selectionHash           String   @db.Char(64)
  inputHash               String   @db.Char(64)
  guardManifest           Json
  fileHash                String?  @db.Char(64)
  normalizedRowsHash      String?  @db.Char(64)
  customerVersionManifest Json
  selectedCustomerIds     Json
  filterSnapshot          Json?
  expiresAt               DateTime
  consumedAt              DateTime?
  consumedResultType      String?  @db.VarChar(64)
  consumedResultId        String?  @db.VarChar(64)
  consumedIdempotencyKey  String?  @db.VarChar(128)
  createdAt               DateTime @default(now())

  @@index([actorId, operation, expiresAt])
  @@index([consumedResultType, consumedResultId])
  @@map("customer_batch_prechecks")
}

model CustomerBatchJob {
  id                     String                 @id @db.VarChar(64)
  handlerKey             String                 @db.VarChar(80)
  operation              String                 @db.VarChar(80)
  status                 String                 @db.VarChar(32)
  selectionMode          String                 @db.VarChar(32)
  selectedCustomerIds    Json
  filterSnapshot         Json?
  input                  Json
  inputHash              String                 @db.Char(64)
  idempotencyFingerprint String                 @db.Char(64)
  reason                 String                 @db.Text
  idempotencyKey         String                 @db.VarChar(128)
  actorId                String                 @db.VarChar(64)
  actorName              String                 @db.VarChar(100)
  actorDepartmentId      String?                @db.VarChar(64)
  frozenCustomerCount    Int
  totalCount             Int                    @default(0)
  successCount           Int                    @default(0)
  failedCount            Int                    @default(0)
  skippedCount           Int                    @default(0)
  cancelledCount         Int                    @default(0)
  leaseOwner             String?                @db.VarChar(64)
  leaseEpoch             Int                    @default(0)
  leaseExpiresAt         DateTime?
  heartbeatAt            DateTime?
  cursor                 Int                    @default(0)
  cancelRequestedAt      DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime               @default(now())
  startedAt              DateTime?
  finishedAt             DateTime?
  expiresAt              DateTime?
  attemptCount           Int                    @default(0)
  lastError              String?                @db.Text
  retryOfJobId           String?                @db.VarChar(64)
  retryOf                CustomerBatchJob?      @relation("CustomerBatchJobRetry", fields: [retryOfJobId], references: [id], onDelete: SetNull)
  retryChildren          CustomerBatchJob[]     @relation("CustomerBatchJobRetry")
  items                  CustomerBatchJobItem[]

  @@unique([actorId, handlerKey, operation, idempotencyKey])
  @@index([status, leaseExpiresAt])
  @@index([retryOfJobId])
  @@map("customer_batch_jobs")
}

model CustomerBatchJobItem {
  id                String           @id @db.VarChar(64)
  jobId             String           @db.VarChar(64)
  targetKey         String           @db.VarChar(120)
  status            String           @db.VarChar(32)
  errorCode         String?          @db.VarChar(64)
  errorMessage      String?          @db.Text
  expectedUpdatedAt DateTime?
  beforeHash        String?          @db.Char(64)
  afterHash         String?          @db.Char(64)
  beforeSnapshot    Json?
  afterSnapshot     Json?
  idempotencyKey    String           @unique @db.VarChar(191)
  attemptCount      Int              @default(0)
  retryable         Boolean          @default(false)
  startedAt         DateTime?
  finishedAt        DateTime?
  job               CustomerBatchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, targetKey], map: "customer_batch_job_item_target_unique")
  @@index([jobId, status])
  @@map("customer_batch_job_items")
}

model CustomerAuditEvent {
  id             String   @id @db.VarChar(64)
  eventSequence  BigInt   @unique @default(autoincrement())
  customerId     String   @db.VarChar(80)
  batchJobId     String?  @db.VarChar(64)
  operation      String   @db.VarChar(80)
  actorId        String   @db.VarChar(64)
  actorName      String   @db.VarChar(100)
  reason         String?  @db.Text
  inputHash      String?  @db.Char(64)
  beforeSnapshot Json?
  afterSnapshot  Json?
  result         String   @db.VarChar(32)
  requestId      String?  @db.VarChar(128)
  idempotencyKey String?  @db.VarChar(191)
  ip             String?  @db.VarChar(64)
  createdAt      DateTime @default(now())

  @@index([customerId, eventSequence])
  @@index([batchJobId, createdAt])
  @@map("customer_audit_events")
}

model ContactIdentity {
  id                       String                @id @db.VarChar(64)
  type                     String                @db.VarChar(32)
  normalizedHash           String                @db.Char(64)
  hashKeyVersion           Int
  status                   String                @db.VarChar(32)
  encryptedNormalizedValue String                @db.Text
  canonicalCustomerId      String?               @db.VarChar(80)
  conflictReason           String?               @db.Text
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  links                    ContactIdentityLink[]

  @@unique([type, normalizedHash])
  @@map("contact_identities")
}

model ContactIdentityLink {
  id         String          @id @db.VarChar(64)
  identityId String          @db.VarChar(64)
  entityType String          @db.VarChar(32)
  entityId   String          @db.VarChar(80)
  linkStatus String          @db.VarChar(32)
  source     String          @db.VarChar(64)
  createdAt  DateTime        @default(now())
  endedAt    DateTime?
  identity   ContactIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@unique([identityId, entityType, entityId])
  @@index([entityType, entityId, linkStatus])
  @@map("contact_identity_links")
}

model CustomerDuplicateGroup {
  id                String   @id @db.VarChar(64)
  groupKey          String   @unique @db.Char(64)
  rule              String   @db.VarChar(80)
  confidence        String   @db.VarChar(32)
  status            String   @db.VarChar(32)
  customerIds       Json
  contactIdentityId String?  @db.VarChar(64)
  sourceJobId       String?  @db.VarChar(64)
  createdById       String?  @db.VarChar(64)
  createdAt         DateTime @default(now())
  resolvedAt        DateTime?
  mergeLedgerId     String?  @db.VarChar(64)

  @@index([status, createdAt])
  @@index([contactIdentityId])
  @@map("customer_duplicate_groups")
}

model CustomerMergeLedger {
  id                   String   @id @default(cuid()) @db.VarChar(64)
  duplicateGroupId     String?  @db.VarChar(64)
  mainCustomerId       String   @db.VarChar(80)
  secondaryCustomerIds Json
  fieldDecisions       Json
  tagDecision          Json
  encryptedCustomerSnapshots String @db.LongText
  snapshotKeyVersion   Int
  guardManifest        Json
  reason               String   @db.Text
  actorId              String   @db.VarChar(64)
  actorName            String   @db.VarChar(100)
  mergeInputHash       String   @db.Char(64)
  mergeIdempotencyKey  String   @db.VarChar(80)
  mergeIdempotencyFingerprint String @db.Char(64)
  mergedAt             DateTime @default(now())
  undoDeadlineAt       DateTime
  status               String   @default("merged") @db.VarChar(32)
  undoneAt             DateTime?
  undoneById           String?  @db.VarChar(64)
  undoneByName         String?  @db.VarChar(100)
  undoInputHash        String?  @db.Char(64)
  undoIdempotencyKey   String?  @db.VarChar(80)
  undoIdempotencyFingerprint String? @db.Char(64)
  lastUndoBlockedAt    DateTime?
  undoConflicts        Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  entries              CustomerMergeLedgerEntry[]

  @@index([mainCustomerId])
  @@index([duplicateGroupId])
  @@index([status, undoDeadlineAt])
  @@unique([actorId, mergeIdempotencyKey])
  @@unique([undoneById, undoIdempotencyKey])
  @@map("customer_merge_ledgers")
}

model CustomerMergeLedgerEntry {
  id             String   @id @default(cuid()) @db.VarChar(64)
  ledgerId       String   @db.VarChar(64)
  domain         String   @db.VarChar(80)
  recordId       String   @db.VarChar(160)
  beforeSnapshot Json
  afterSnapshot  Json
  rowRevision    Int?
  updatedAtValue DateTime?
  createdAt      DateTime @default(now())
  ledger         CustomerMergeLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@unique([ledgerId, domain, recordId])
  @@index([domain, recordId])
  @@map("customer_merge_ledger_entries")
}
