{
  "name": "ai-agent-ops-saas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 127.0.0.1 --port 3000 --strictPort",
    "dev:api": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "test": "tsx scripts/run-tests.ts",
    "preview": "vite preview",
    "prod:check": "tsx scripts/deploy/check-production-config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "delivery:repair": "tsx scripts/repair-deliveries.ts",
    "business-records:repair": "tsx scripts/repair-legacy-business-records.ts",
    "customer-contacts:backfill": "tsx scripts/backfill-contact-identities.ts",
    "customer:permission-audit": "tsx scripts/audit-customer-permission-migration.ts",
    "customer:association-audit": "tsx scripts/audit-customer-associations.ts",
    "customer:batch-verify": "tsx scripts/verify-customer-batch-foundation.ts"
  },
  "overrides": {
    "effect": "3.21.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^6.0.0",
    "@mui/material": "^6.0.0",
    "@prisma/client": "6.19.3",
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "mysql2": "^3.22.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^2.12.0",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.4",
    "uuid": "^11.1.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
